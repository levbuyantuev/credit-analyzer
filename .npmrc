auto-install-peers=false
strict-peer-dependencies=false

# Фиксируем версию lockfile для совместимости
lockfile-version=6

# Игнорируем несовпадения конфигурации при установке (безопасно для деплоя)
ignore-workspace-root-check=true

# Отключаем строгую проверку конфигурации в CI/CD
config-mismatch-check=false
